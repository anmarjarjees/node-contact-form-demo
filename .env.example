# NODE Contact Form Demonstration
# Environment Variables Configuration

# SMTP Configuration:

# SMTP Server Host
SMTP_HOST=mail.DomainName.com

# SMTP Port
# Common values:
# 465 = SSL
# 587 = STARTTLS
SMTP_PORT=465

# SMTP Account Username
SMTP_USER=ID@DomainName.com

# SMTP Account Password
SMTP_PASSWORD=email-password

# Express Server Port
PORT=3000